{
  "manifestVersion": 4,
  "id": "com.imperial.printos",
  "name": "Imperial Print OS",
  "version": "0.1.2",
  "main": "index.html",
  "host": {
    "app": "PS",
    "minVersion": "23.0.0"
  },
  "entrypoints": [
    {
      "type": "panel",
      "id": "imperialPrintPanel",
      "label": {
        "default": "Imperial Print OS"
      },
      "minimumSize": {
        "width": 320,
        "height": 480
      },
      "maximumSize": {
        "width": 1200,
        "height": 2000
      },
      "preferredDockedSize": {
        "width": 360,
        "height": 640
      },
      "preferredFloatingSize": {
        "width": 420,
        "height": 700
      }
    }
  ]
}
