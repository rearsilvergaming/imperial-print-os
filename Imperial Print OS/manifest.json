{
  "manifestVersion": 4,
  "id": "com.imperial.printos",
  "name": "Imperial Print OS",
  "version": "0.2.0",
  "main": "index.html",
  "host": {
    "app": "PS",
    "minVersion": "23.0.0",
    "data": {
      "apiVersion": 2,
      "enableMenuRecording": true
    }
  },
  "entrypoints": [
    {
      "type": "panel",
      "id": "primary",
      "label": {
        "default": "Imperial Print OS"
      },
      "minimumSize": {
        "width": 260,
        "height": 320
      },
      "maximumSize": {
        "width": 520,
        "height": 1200
      },
      "preferredDockedSize": {
        "width": 340,
        "height": 760
      },
      "preferredFloatingSize": {
        "width": 360,
        "height": 780
      }
    }
  ]
}
